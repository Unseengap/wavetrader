# ─────────────────────────────────────────────────────────────
# WaveTrader Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── OANDA Demo (Practice) Account ─────────────────────────────
# Get your API key from: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_DEMO_API_KEY=your-demo-api-key-here
OANDA_DEMO_ACCOUNT_ID=101-001-12345678-001

# ── OANDA Live Account (OPTIONAL) ────────────────────────────
# The agent trades on demo by default. If you also configure a live
# account, the agent will place orders on BOTH accounts simultaneously.
# Leave blank to trade demo only.
OANDA_LIVE_API_KEY=
OANDA_LIVE_ACCOUNT_ID=

# ── Trading Config ────────────────────────────────────────────
PAIR=GBP/JPY
INITIAL_BALANCE=10000

# ── Checkpoint / State ────────────────────────────────────────
CHECKPOINT_DIR=/data/checkpoints
CHECKPOINT_INTERVAL=100
# Path to trained model weights (from training):
CHECKPOINT_PATH=/checkpoints/wavetrader_mtf_GBPJPY_20260404_235854/model_weights.pt

# ── Telegram Alerts (OPTIONAL) ────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Signal Channel (OPTIONAL — for broadcasting to subscribers) ──
# Create a Telegram channel, add your bot as admin, then set the channel ID.
# Channel IDs look like: -1001234567890 (or use @your_channel_name)
TELEGRAM_CHANNEL_ID=

# ── Multi-User / Copy Trading ────────────────────────────────
# Directory where user registry (users.json) is stored:
DATA_DIR=data
# Users are added via: python cli.py --mode add-user
