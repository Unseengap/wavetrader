# ─────────────────────────────────────────────────────────────
# WaveTrader Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── OANDA Demo (Practice) Account ─────────────────────────────
# Get your API key from: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_DEMO_API_KEY=your-demo-api-key-here
OANDA_DEMO_ACCOUNT_ID=101-001-12345678-001

# ── OANDA Live Account (OPTIONAL) ────────────────────────────
# The agent trades on demo by default. If you also configure a live
# account, the agent will place orders on BOTH accounts simultaneously.
# Leave blank to trade demo only.
OANDA_LIVE_API_KEY=
OANDA_LIVE_ACCOUNT_ID=

# ── Multi-Model OANDA Accounts ───────────────────────────────
# Each AI model trades on its own OANDA account independently.
# The default model (MTF) uses OANDA_DEMO_ACCOUNT_ID above.
# Override per-model with MTF_ / WF_ prefixes:
#
# MTF_OANDA_DEMO_ACCOUNT_ID=101-001-12345678-001
# MTF_OANDA_LIVE_ACCOUNT_ID=
#
# WaveFollower (trend-following model):
# WF_OANDA_DEMO_API_KEY=        (same API key if same user)
# WF_OANDA_DEMO_ACCOUNT_ID=101-001-87654321-001
# WF_OANDA_LIVE_API_KEY=
# WF_OANDA_LIVE_ACCOUNT_ID=
#
# MeanReversion (mean-reversion model):
# MR_OANDA_DEMO_API_KEY=        (same API key if same user)
# MR_OANDA_DEMO_ACCOUNT_ID=101-001-87654321-002
# MR_OANDA_LIVE_API_KEY=
# MR_OANDA_LIVE_ACCOUNT_ID=
#
# MODEL_REGISTRY (JSON) — defines all models for the dashboard dropdown.
# If not set, only the default MTF model is shown.
# Example with MTF + WaveFollower + MeanReversion:
# MODEL_REGISTRY=[{"id":"mtf","name":"WaveTrader MTF","pair":"GBP/JPY","model_type":"mtf","demo_api_key_env":"OANDA_DEMO_API_KEY","demo_account_id_env":"OANDA_DEMO_ACCOUNT_ID","checkpoint_dir":"checkpoints/wavetrader_mtf_GBPJPY_20260404_235854"},{"id":"wavefollower","name":"WaveFollower","pair":"GBP/JPY","model_type":"wavefollower","description":"Trend-following with pullback pyramiding","demo_api_key_env":"WF_OANDA_DEMO_API_KEY","demo_account_id_env":"WF_OANDA_DEMO_ACCOUNT_ID","checkpoint_dir":"checkpoints/wavefollower_20260412_023912","results_dir":"wavefollower_20260412_023912"},{"id":"meanrev","name":"MeanReversion","pair":"GBP/JPY","model_type":"meanrev","description":"Mean-reversion — profit when prices snap back to average; ~71% win rate","demo_api_key_env":"MR_OANDA_DEMO_API_KEY","demo_account_id_env":"MR_OANDA_DEMO_ACCOUNT_ID"}]
MODEL_REGISTRY=

# ── Trading Config ────────────────────────────────────────────
PAIR=GBP/JPY
INITIAL_BALANCE=10000

# ── Checkpoint / State ────────────────────────────────────────
CHECKPOINT_DIR=/data/checkpoints
CHECKPOINT_INTERVAL=100
# Path to trained model weights (from training):
CHECKPOINT_PATH=/checkpoints/wavetrader_mtf_GBPJPY_20260404_235854/model_weights.pt

# ── Telegram Alerts (OPTIONAL) ────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → get token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Signal Channel (OPTIONAL — for broadcasting to subscribers) ──
# Create a Telegram channel, add your bot as admin, then set the channel ID.
# Channel IDs look like: -1001234567890 (or use @your_channel_name)
TELEGRAM_CHANNEL_ID=

# ── Multi-User / Copy Trading ────────────────────────────────
# Directory where user registry (users.json) is stored:
DATA_DIR=data
# Users are added via: python cli.py --mode add-user

# ── LLM Arbiter (Google Gemini) ──────────────────────────────
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyCzsPNs3Mn4kp321kJqP9U1Hkb8LH2utio
# Enable the LLM signal arbiter (true/false)
LLM_ARBITER_ENABLED=false
# Authority mode: advisory (log only), veto (can block trades), override (can modify trades)
LLM_AUTHORITY_MODE=advisory
# Gemini model: gemini-2.5-flash (fast/cheap) or gemini-2.5-pro (deeper reasoning)
LLM_MODEL=gemini-2.5-flash
